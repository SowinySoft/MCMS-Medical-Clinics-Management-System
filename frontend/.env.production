# Build-time API/WS origins for the miget-hosted SPA (public URLs, not secrets).
# Dashboard Environment Variables (VITE_API_BASE / VITE_WS_BASE) override these
# if miget injects them at build time; this file is the fallback so the SPA
# always builds pointing at the live MCMS backend.
VITE_API_BASE=https://mcms-jkqhy.eu-east-1.migetapp.com/api
VITE_WS_BASE=wss://mcms-jkqhy.eu-east-1.migetapp.com/ws/events/
