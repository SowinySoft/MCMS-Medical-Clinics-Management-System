# MCMS deployment environment — copy to `.env` and fill in real values.
# (`.env` is gitignored; this file is the template.)

# ---- Database ----
MCMS_DB_HOST=db
MCMS_DB_PORT=5432
MCMS_DB_USER=postgres
MCMS_DB_PASSWORD=postgres
MCMS_DB_NAME=mcms

# ---- Django ----
MCMS_SECRET_KEY=change-me-to-a-long-random-string
MCMS_DEBUG=false
MCMS_ALLOWED_HOSTS=localhost,127.0.0.1,your.domain.here

# ---- Channels (WebSocket live feed) ----
MCMS_REDIS_URL=redis://redis:6379/0

# ---- Initial users (provisioned idempotently on first boot) ----
MCMS_ADMIN_USER=admin
MCMS_ADMIN_PASS=admin123
MCMS_ACC1_USER=acc1
MCMS_ACC1_PASS=acc1123

# ---- Test database (CI / local pytest) ----
# The backend test suite builds mcms_test from committed sql/ artifacts:
#   MODE=from-sql bash scripts/rebuild_test_db.sh
# No dump or live DB connection required.
